# ==============================================
# Quant-Trade System 环境变量配置
# ==============================================
# 复制此文件为 .env 并填入真实配置
# WARNING: .env 文件包含敏感信息，不要提交到 Git

# ==============================================
# 应用配置
# ==============================================
APP_NAME=Quant-Trade-System
APP_VERSION=1.0.0
APP_ENV=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ==============================================
# 服务器配置
# ==============================================
# 后端 API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1

# 前端
FRONTEND_URL=http://localhost:3000

# ==============================================
# 数据库配置 - PostgreSQL
# ==============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quant_trade
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=quant_trade
POSTGRES_MAX_CONNECTIONS=20

# ==============================================
# 缓存配置 - Redis
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10

# ==============================================
# 消息队列 - RabbitMQ
# ==============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ==============================================
# Celery 配置
# ==============================================
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIMEOUT=300

# ==============================================
# 数据源 API 配置
# ==============================================
# Tushare
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_PRO_API=https://api.tushare.pro

# AkShare (无需 Token)

# Wind (如有)
WIND_USERNAME=
WIND_PASSWORD=

# ==============================================
# 券商接口配置
# ==============================================
BROKER_TYPE=simulated  # simulated | xtp | tdx
BROKER_HOST=
BROKER_PORT=7709
BROKER_USERNAME=
BROKER_PASSWORD=
BROKER_ACCOUNT_ID=

# ==============================================
# JWT 认证配置
# ==============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================
# OAuth 配置（可选）
# ==============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==============================================
# 邮件配置
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@quanttrade.example.com
EMAIL_FROM_NAME=Quant-Trade System

# ==============================================
# 监控和日志
# ==============================================
# Sentry
SENTRY_DSN=

# Prometheus
METRICS_ENABLED=true
METRICS_PORT=9090

# 日志文件
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=10 days
LOG_RETENTION=30 days

# ==============================================
# 交易配置
# ==============================================
# 模拟交易
PAPER_TRADING=true
PAPER_TRADING_INITIAL_CAPITAL=1000000

# 风控配置
MAX_POSITION_RATIO=0.3
MAX_SINGLE_STOCK_RATIO=0.1
MAX_DAILY_LOSS_RATIO=0.05
STOP_LOSS_RATIO=0.08

# 交易时间
MARKET_OPEN_TIME=09:30:00
MARKET_CLOSE_TIME=15:00:00
PRE_MARKET_START_TIME=09:15:00

# ==============================================
# AI/ML 配置
# ==============================================
# GLM API
GLM_API_KEY=your_glm_api_key
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/

# OpenAI (可选)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ==============================================
# 存储配置
# ==============================================
# 文件存储
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=10485760  # 10MB

# 对象存储（可选）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# ==============================================
# 第三方服务
# ==============================================
# 数据质量监控
DATA_QUALITY_CHECK_ENABLED=true
DATA_QUALITY_THRESHOLD=0.95

# 通知服务
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNEL=email  # email | sms | webhook
WEBHOOK_URL=

# ==============================================
# 开发工具
# ==============================================
# Hot Reload
HOT_RELOAD=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ==============================================
# 性能配置
# ==============================================
# 连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 缓存
CACHE_TTL=300  # 5 minutes
CACHE_MAX_SIZE=1000

# 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ==============================================
# 安全配置
# ==============================================
# HTTPS
HTTPS_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true

# Session
SESSION_EXPIRE_HOURS=24
MAX_SESSIONS_PER_USER=5

# ==============================================
# 功能开关
# ==============================================
FEATURE_DATA_DOWNLOAD=true
FEATURE_BACKTEST=true
FEATURE_LIVE_TRADING=false
FEATURE_AI_OPTIMIZATION=true
FEATURE_SOCIAL_TRADING=false

# ==============================================
# 备份配置
# ==============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 每天 2:00 AM
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=backups/

# ==============================================
# 其他配置
# ==============================================
TIMEZONE=Asia/Shanghai
LOCALE=zh_CN
CURRENCY=CNY
