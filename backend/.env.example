# ==============================================
# QuantAI Ecosystem - 环境变量配置
# ==============================================
# 复制此文件为 .env 并填写实际值
# ==============================================

# ==============================================
# 应用配置
# ==============================================
APP_NAME=QuantAI_Ecosystem
APP_VERSION=2.0.0
APP_ENV=development                   # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ==============================================
# 服务器配置
# ==============================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==============================================
# 数据库配置
# ==============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quant_trio
POSTGRES_PASSWORD=quant_trio_pass
POSTGRES_DB=quant_trio

# 数据库连接池
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==============================================
# Redis 配置
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ==============================================
# 认证配置
# ==============================================
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================
# 外部 API 密钥
# ==============================================
# Tushare Token
TUSHARE_TOKEN=your-tushare-token

# Alpha Vantage（美股数据）
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# OpenAI API（可选，用于 AI 功能）
OPENAI_API_KEY=your-openai-api-key

# GLM API（智谱 AI，用于 AI 策略生成、智能选股、市场分析）
GLM_API_KEY=your-glm-api-key
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4

# ==============================================
# 交易配置
# ==============================================
# 默认最大滑点（0.1%）
DEFAULT_MAX_SLIPPAGE=0.001

# 默认最大单仓比例（30%）
DEFAULT_MAX_POSITION_RATIO=0.3

# 默认最大单日亏损比例（5%）
DEFAULT_MAX_DAILY_LOSS_RATIO=0.05

# ==============================================
# 风控配置
# ==============================================
# 启用实时风控
RISK_CONTROL_ENABLED=true

# 风险检查间隔（秒）
RISK_CHECK_INTERVAL=60

# ==============================================
# 日志配置
# ==============================================
# 日志文件路径
LOG_FILE_PATH=logs/app.log

# 日志保留天数
LOG_RETENTION_DAYS=30

# ==============================================
# Celery 配置
# ==============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
